---
import Base from '../layouts/Base.astro'
---
<Base headerClass="header--home">
  <section slot="head">
    <title>Sumaq Perú — Inicio</title>
    <meta name="description" content="Asociación Cultural Sumaq Perú — preservando y promoviendo la cultura andina.">
  </section>

  <main>
    <section class="hero fullpage">
      <div class="hero-container">
        <h2>Bienvenidos a Sumaq Perú</h2>
        <p>Asociación Cultural Andina dedicada a preservar y promover la riqueza cultural andina.</p>
        <a href="/nosotros" class="btn">Conócenos</a>
      </div>
    </section>

    <section class="home-cards fullpage">
      <div class="card">
        <h3>Actividades</h3>
        <p>Talleres, eventos y programas culturales.</p>
        <a href="/actividades">Ver actividades</a>
      </div>
      <div class="card">
        <h3>Galería</h3>
        <p>Imágenes y videos de nuestras acciones.</p>
        <a href="/galeria">Ver galería</a>
      </div>
      <div class="card">
        <h3>Contacto</h3>
        <p>Escríbenos para participar o colaborar.</p>
        <a href="/contacto">Contáctanos</a>
      </div>
    </section>
  </main>
</Base>
